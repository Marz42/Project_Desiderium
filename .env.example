# Application
DATABASE_URL=postgresql+asyncpg://desiderium:desiderium@postgres:5432/desiderium
YOUTUBE_DATA_API_KEY=
YOUTUBE_API_KEY=
YOUTUBE_DAILY_QUOTA_LIMIT=10000
YOUTUBE_MAX_SEARCH_CALLS=100
CRAWL_PRIORITY_HOURS=5
CRAWL_GENERAL_HOURS=18
CRAWL_KEYWORD_HOUR=6
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
SECRET_KEY=change-me-in-production
MANAGER_PASSWORD=
LOG_LEVEL=INFO
ENVIRONMENT=development

# TikTok experimental adapter (off by default; cookie never committed to git)
TIKTOK_ENABLED=false
TIKTOK_COOKIE=
TIKTOK_PAGE_VERSION=v1
TIKTOK_CRAWL_HOURS=12
TIKTOK_RETRY_HOURS=2

# Production / ops (Stage 8)
DOMAIN=desiderium.example.com
ACME_EMAIL=ops@example.com
POSTGRES_USER=desiderium
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=desiderium
SNAPSHOT_RETENTION_DAYS=90
DISK_WARN_PERCENT=85
BACKUP_RETENTION_DAYS=14
WORKER_STALE_MINUTES=15
LLM_COST_PER_MILLION_INPUT_USD=0.15
LLM_COST_PER_MILLION_OUTPUT_USD=0.60
